# Mootive Frontend - copy to .env after `sam deploy` and fill from the SAM Outputs section.

# HTTP API base URL (no trailing slash).
VITE_API_BASE_URL=

VITE_AWS_REGION=us-east-1

# Cognito (User Pool + App Client + Identity Pool)
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_USER_POOL_CLIENT_ID=
VITE_COGNITO_IDENTITY_POOL_ID=

# Amazon Location Service
VITE_MAP_NAME=mootive-map
VITE_PLACE_INDEX_NAME=mootive-places

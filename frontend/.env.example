# Mootive Frontend — copy to .env.local after `sam deploy` and fill from the SAM Outputs section.

# HTTP API base URL (no trailing slash). Can also be set at runtime via the Settings button on the phone frame.
VITE_API_URL=

VITE_REGION=us-east-1

# Cognito (User Pool + App Client + Identity Pool)
VITE_USER_POOL_ID=
VITE_USER_POOL_CLIENT_ID=
VITE_IDENTITY_POOL_ID=

# Amazon Location Service
VITE_MAP_NAME=mootive-map
VITE_PLACE_INDEX_NAME=mootive-places
